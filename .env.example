# ─── Docker image (for compose.ghcr.yml) ────────────────────────
COOKDEX_IMAGE=ghcr.io/thekannen/cookdex
COOKDEX_TAG=latest

# ─── Optional server overrides ──────────────────────────────────
# WEB_BIND_PORT=4820          # Host port (default 4820)
# WEB_BASE_PATH=/cookdex      # URL route prefix
# WEB_BIND_HOST=0.0.0.0       # Interface to bind

# ─── HTTPS / TLS ─────────────────────────────────────────────────
# WEB_SSL=true                # Default: enabled with auto-generated self-signed cert
                               # Set to false to disable (e.g. behind a reverse proxy)
# WEB_SSL_CERTFILE=            # Path to your own TLS certificate (PEM)
# WEB_SSL_KEYFILE=             # Path to your own TLS private key (PEM)
# WEB_COOKIE_SECURE=           # Auto-detected from SSL; override only if needed

# ─── Advanced / headless deployments ────────────────────────────
# WEB_BOOTSTRAP_PASSWORD=     # Pre-create admin on first start (skips UI registration)
# MO_WEBUI_MASTER_KEY=        # Override the auto-generated encryption key

# ─── Pre-seed Mealie connection (optional — can also be set in UI) ───
# MEALIE_URL=http://your.mealie.host:9000/api
# MEALIE_API_KEY=your_mealie_api_key

# ─── AI providers (optional — can also be set in UI) ─────────────────
# CATEGORIZER_PROVIDER=chatgpt     # chatgpt, anthropic, or ollama
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=your_openai_api_key
# ANTHROPIC_MODEL=
# ANTHROPIC_API_KEY=your_anthropic_api_key
# OLLAMA_URL=http://host.docker.internal:11434/api
# OLLAMA_MODEL=
# OLLAMA_BATCH_SIZE=10             # Smaller batches reduce local-model JSON truncation
# OLLAMA_NUM_CTX=4096              # Context window for local model prompts
# OLLAMA_NUM_PREDICT=4096          # Maximum generated tokens per Ollama request

# ─── Recipe Dredger (optional — managed in Settings and Recipe Sources page) ───
# DREDGER_TARGET_LANGUAGE=en          # ISO language code for recipe filtering
# DREDGER_CRAWL_DELAY=2.0             # Seconds between requests to same domain
# DREDGER_CACHE_EXPIRY_DAYS=7         # Days before sitemap cache is stale

# ─── Direct DB access (optional — enables --use-db on bulk tasks) ────
# Bypasses HTTP API for bulk operations; dramatically faster on large libraries.
# MEALIE_DB_TYPE=postgres
# MEALIE_PG_HOST=localhost
# MEALIE_PG_PORT=5432
# MEALIE_PG_DB=mealie_db
# MEALIE_PG_USER=mealie__user
# MEALIE_PG_PASS=your_mealie_db_password
# MEALIE_DB_SSH_HOST=your.mealie.host.ip
# MEALIE_DB_SSH_USER=root
# MEALIE_DB_SSH_KEY=/app/.ssh/cookdex_mealie
# MEALIE_SQLITE_PATH=/app/data/mealie.db   # Env-only advanced SQLite path
